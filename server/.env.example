# =============================================================
# OB Server — Environment Variables Template
# 复制此文件为 .env 并填入真实值，.env 已加入 .gitignore
# =============================================================

# 应用端口（Railway 会自动注入 PORT）
PORT=3000

# PostgreSQL 数据库连接串
# 格式：postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://ob_user:password@localhost:5432/ob_db

# Redis 连接串（BullMQ 任务队列使用）
# 格式：redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# JWT 签名密钥（生产环境请使用 64 位以上随机字符串）
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_64_chars

# JWT 有效期（支持 vercel/ms 格式，如 7d / 24h / 3600s）
JWT_EXPIRES_IN=7d

# 微信小程序 AppID 和 AppSecret
# 开发阶段使用 mock 模式，此值可留空
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret

# 是否启用微信 Mock 模式（true = 任意 code 均有效，仅用于开发/测试）
WECHAT_MOCK=true

# 运行环境（development / production）
NODE_ENV=development

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://pub-9b13cc2e33104018a9cce774320589e2.r2.dev
R2_S3_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
